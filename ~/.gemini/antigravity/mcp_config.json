{
    "mcpServers": {
        "dart-mcp-server": {
            "command": "dart",
            "args": [
                "mcp-server"
            ],
            "env": {}
        },
        "google-developer-knowledge": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-remote",
                "https://developerknowledge.googleapis.com/mcp",
                "--header",
                "X-Goog-Api-Key: AIzaSyDQi_A51gNoGnpszJSyCtDc1CpCTIZH_8g"
            ],
            "env": {}
        },
        "firebase-mcp-server": {
            "command": "npx",
            "args": [
                "-y",
                "firebase-tools@latest",
                "mcp"
            ]
        }
    }
}